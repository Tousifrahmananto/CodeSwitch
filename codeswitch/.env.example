SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (use SQLite for dev by leaving DB_ENGINE blank)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=codeswitch_db
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_HOST=localhost
DB_PORT=5432

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Google Sign-In
GOOGLE_OAUTH_CLIENT_ID=********

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000

# Production example for the Vercel frontend
# CORS_ALLOWED_ORIGINS=https://your-app.vercel.app
# CSRF_TRUSTED_ORIGINS=https://your-app.vercel.app

# PostgreSQL-backed shared cache for production rate limiting
CACHE_KEY_PREFIX=codeswitch
CACHE_TABLE_NAME=codeswitch_cache
TRUSTED_PROXY_COUNT=0
# Required in production: set to Railway's verified proxy-hop count.
# TRUSTED_PROXY_COUNT=1

# Unsafe local-only Python execution tracer. Production startup rejects true.
PYTHON_EXECUTION_TRACING_ENABLED=False

# Database startup retry behavior for transient Railway/Postgres recovery windows
DB_REQUEST_RETRY_ATTEMPTS=3
DB_REQUEST_RETRY_DELAY_SECONDS=0.25

# Observability
SERVICE_NAME=codeswitch-backend
DEPLOYMENT_ENVIRONMENT=development
LOG_FORMAT=console
LOG_LEVEL=INFO
METRICS_ENABLED=True
METRICS_BEARER_TOKEN=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=0.10
OTEL_METRICS_EXPORT_INTERVAL=60000
CONVERSION_HISTORY_RETENTION_DAYS=180
MEDIA_ROOT=

# ── AI Code Conversion ─────────────────────────────────────────────────────────
# Supported providers:
#   gemini  → Google Gemini (free tier: aistudio.google.com)
#   openai  → OpenAI (platform.openai.com)
#   groq    → Groq (free tier: console.groq.com)
# If AI_API_KEY is blank the rule-based engine is used as fallback.
AI_PROVIDER=gemini
AI_API_KEY=
# AI_API_KEY_2=  (optional: fallback key — used if key #1 hits a rate limit/auth error)
# AI_API_KEY_3=  (optional: third fallback key)
AI_MODEL=gemini-2.0-flash
# AI_BASE_URL=   (optional: override API base URL for custom/self-hosted endpoints)
