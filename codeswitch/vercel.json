{
  "version": 2,
  "installCommand": "pip install --break-system-packages -r requirements.txt",
  "buildCommand": "python manage.py migrate --noinput && python manage.py collectstatic --noinput",
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ]
}
