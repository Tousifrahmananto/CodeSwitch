# Normalize line endings to LF in the repo (cross-platform safe)
* text=auto eol=lf

# Force these to always be LF
*.py    text eol=lf
*.jsx   text eol=lf
*.js    text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.env   text eol=lf

# Binary files — never convert
*.png   binary
*.jpg   binary
*.jpeg  binary
*.ico   binary
*.gif   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
