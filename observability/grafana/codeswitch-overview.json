{
  "annotations": {"list": []},
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "type": "stat", "title": "Requests / second", "id": 1,
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 0},
      "targets": [{"expr": "sum(rate(codeswitch_http_requests_total[$__rate_interval]))", "refId": "A"}]
    },
    {
      "type": "stat", "title": "5xx error rate", "id": 2,
      "gridPos": {"h": 5, "w": 6, "x": 6, "y": 0},
      "fieldConfig": {"defaults": {"unit": "percentunit"}},
      "targets": [{"expr": "sum(rate(codeswitch_http_requests_total{status=~\"5..\"}[$__rate_interval])) / clamp_min(sum(rate(codeswitch_http_requests_total[$__rate_interval])), 0.001)", "refId": "A"}]
    },
    {
      "type": "stat", "title": "p95 latency", "id": 3,
      "gridPos": {"h": 5, "w": 6, "x": 12, "y": 0},
      "fieldConfig": {"defaults": {"unit": "s"}},
      "targets": [{"expr": "histogram_quantile(0.95, sum by (le) (rate(codeswitch_http_request_duration_seconds_bucket[$__rate_interval])))", "refId": "A"}]
    },
    {
      "type": "stat", "title": "Rate-limit rejections", "id": 4,
      "gridPos": {"h": 5, "w": 6, "x": 18, "y": 0},
      "targets": [{"expr": "sum(increase(codeswitch_rate_limit_rejections_total[$__range]))", "refId": "A"}]
    },
    {
      "type": "timeseries", "title": "Request rate by status", "id": 5,
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 5},
      "targets": [{"expr": "sum by (status) (rate(codeswitch_http_requests_total[$__rate_interval]))", "legendFormat": "{{status}}", "refId": "A"}]
    },
    {
      "type": "timeseries", "title": "Latency percentiles", "id": 6,
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 5},
      "fieldConfig": {"defaults": {"unit": "s"}},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum by (le) (rate(codeswitch_http_request_duration_seconds_bucket[$__rate_interval])))", "legendFormat": "p50", "refId": "A"},
        {"expr": "histogram_quantile(0.95, sum by (le) (rate(codeswitch_http_request_duration_seconds_bucket[$__rate_interval])))", "legendFormat": "p95", "refId": "B"},
        {"expr": "histogram_quantile(0.99, sum by (le) (rate(codeswitch_http_request_duration_seconds_bucket[$__rate_interval])))", "legendFormat": "p99", "refId": "C"}
      ]
    },
    {
      "type": "timeseries", "title": "Conversions by engine", "id": 7,
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 13},
      "targets": [{"expr": "sum by (engine, status) (rate(codeswitch_conversions_total[$__rate_interval]))", "legendFormat": "{{engine}} / {{status}}", "refId": "A"}]
    },
    {
      "type": "timeseries", "title": "Dependency latency p95", "id": 8,
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 13},
      "fieldConfig": {"defaults": {"unit": "s"}},
      "targets": [{"expr": "histogram_quantile(0.95, sum by (le, dependency) (rate(codeswitch_dependency_duration_seconds_bucket[$__rate_interval])))", "legendFormat": "{{dependency}}", "refId": "A"}]
    },
    {
      "type": "timeseries", "title": "Rate limits by scope", "id": 9,
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 13},
      "targets": [{"expr": "sum by (scope) (rate(codeswitch_rate_limit_rejections_total[$__rate_interval]))", "legendFormat": "{{scope}}", "refId": "A"}]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["codeswitch", "production"],
  "templating": {"list": []},
  "time": {"from": "now-6h", "to": "now"},
  "timezone": "browser",
  "title": "CodeSwitch Production Overview",
  "uid": "codeswitch-overview",
  "version": 1
}
